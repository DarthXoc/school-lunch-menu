{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Flask: Run & Debug",
      "type": "debugpy",
      "request": "launch",
      "module": "flask",
      "args": ["run", "--debug", "--host=0.0.0.0", "--port=5000"],
      "env": {
        "FLASK_APP": "app.py",
        "FLASK_ENV": "development"
      },
      "jinja": true,
      "justMyCode": true
    }
  ]
}
